<mvc:View controllerName="thebookshop.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt">
    <Page id="page" title="{i18n>title}">

        <tnt:ToolHeader id="shellLikeToolHeader" class="sapUiTinyMargin">
			<Button id="_IDGenButton2" icon="sap-icon://menu2" type="Transparent" tooltip="Menu" press=".onCollapseExpandPress">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData" priority="NeverOverflow"/>
				</layoutData>
			</Button>
			<Image id="_IDGenImage" src="test-resources/sap/tnt/images/SAP_Logo.png" decorative="false" press="onLogoPressed" tooltip="SAP Logo" width="60px" height="30px">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData1" priority="NeverOverflow"/>
				</layoutData>
			</Image>
			<Title text="The BookShop" wrapping="false" id="productName">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData2" priority="Disappear"/>
				</layoutData>
			</Title>
			<Text text="Second title" wrapping="false" id="secondTitle">
				<layoutData>
					<OverflowToolbarLayoutData id="_IDGenOverflowToolbarLayoutData3" priority="Disappear"/>
				</layoutData>
			</Text>
		</tnt:ToolHeader>

        <HBox id="_IDGenHBox4" >
            <VBox id="_IDGenVBox7" >  
                <!--side navigation-->
                <tnt:SideNavigation id="sideNavigation" selectedKey="walked" expanded="true">
                    <tnt:NavigationList id="_IDGenNavigationList1">
                        <tnt:NavigationListGroup id="_IDGenNavigationListGroup" text="New">
                            <tnt:NavigationListItem id="_IDGenNavigationListItem1" text="Add Book" icon="sap-icon://people-connected" press=".onAddBookPressed" />
                        </tnt:NavigationListGroup>
                        <tnt:NavigationListGroup id="_IDGenNavigationListGroup1" text="Recently used">
                            <tnt:NavigationListItem id="_IDGenNavigationListItem7" text="View Books" icon="sap-icon://kpi-managing-my-area" press=".onViewBookPressed" />
                            <tnt:NavigationListItem id="_IDGenNavigationListItem8" text="Place Order" icon="sap-icon://cart" press=".onPlaceOrderPressed" />
                            <tnt:NavigationListItem id="_IDGenNavigationListItem9" text="View Orders" icon="sap-icon://sales-order" press=".onViewOrdersPressed" />
                        </tnt:NavigationListGroup>
                    </tnt:NavigationList>
                </tnt:SideNavigation>
            </VBox> 

            <VBox id="_IDGenVBox8" >  
                <!--Panel 1-->
                <Panel id="Panel1" width="60rem" class="sapUiResponsiveMargin" accessibleRole="Region" visible="false">
                    <headerToolbar>
                        <OverflowToolbar id="_IDGenOverflowToolbar">
                            <Title id="_IDGenTitle" text="Add a book"/>
                        </OverflowToolbar>
                    </headerToolbar>   

                    <HBox id="_IDGenHBox" >
                        <VBox id="_IDGenVBox" >
                            <Label id="_IDGenLabel" text="Title"></Label>
                            <Input placeholder="Enter your title" id="title"></Input>
                        </VBox>
                        <VBox id="_IDGenVBox1" >
                            <Label id="_IDGenLabel1" text="Author"></Label>
                            <Input placeholder="Enter the author name" id="author"></Input>
                        </VBox>
                        <VBox id="_IDGenVBox2" >
                            <Label id="_IDGenLabel2" text="Price"></Label>
                            <Input placeholder="Enter the price" id="price"></Input>
                        </VBox>
                    </HBox>

                    <HBox id="_IDGenHBox1" >
                        <VBox id="_IDGenVBox3" >
                            <Label id="_IDGenLabel3" text="Stock"></Label>
                            <Input placeholder="Enter the stock" id="stock"></Input>
                        </VBox>
                        <VBox id="_IDGenVBox4" >
                            <Label id="_IDGenLabel4" text="Location"></Label>
                            <Input placeholder="Enter the location" id="location"></Input>
                        </VBox>
                        <VBox id="_IDGenVBox5" >
                            <Label id="_IDGenLabel5" text="Genre"></Label>
                            <Input placeholder="Enter the genre" id="genre"></Input>
                        </VBox>
                    </HBox>

                    <HBox id="_IDGenHBox3" >
                        <VBox id="_IDGenVBox6" >
                            <Button id="_IDGenButton" press="submit" text="Submit"></Button>
                        </VBox>
                    </HBox>
                </Panel>
                <!--Panel 2-->
                <Panel id="Panel2" headerText="Book Details" visible="false" class="sapUiResponsiveMargin">
                    <!--Books table-->
                    <Table id="booksTable" items="{/Books}">
                        <columns>
                            <Column id="_IDGenColumn1" >
                                <Text id="_IDGenText" text="Title"></Text>
                            </Column>
                            <Column id="_IDGenColumn2" >
                                <Text id="_IDGenText1" text="Author"></Text>
                            </Column>
                            <Column id="_IDGenColumn3" >
                                <Text id="_IDGenText2" text="Price"></Text>
                            </Column>
                            <Column id="_IDGenColumn4" >
                                <Text id="_IDGenText3" text="Stock"></Text>
                            </Column>
                            <Column id="_IDGenColumn5" >
                                <Text id="_IDGenText4" text="Location"></Text>
                            </Column>
                            <Column id="_IDGenColumn6" >
                                <Text id="_IDGenText5" text="Genre"></Text>
                            </Column>
                            <Column id="_IDGenColumn7" >
                                <Text id="_IDGenText6" text="Action"></Text>
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem id="_IDGenColumnListItem" >
                                <cells>
                                    <Text id="_IDGenText7" text="{title}"></Text>
                                    <Text id="_IDGenText8" text="{author}"></Text>
                                    <Text id="_IDGenText9" text="{price}"></Text>
                                    <Text id="_IDGenText10" text="{stock}"></Text>
                                    <Text id="_IDGenText11" text="{location}"></Text>
                                    <Text id="_IDGenText12" text="{genre}"></Text>
                                    <Button id="button1" text="..." press="onActionPressed($event)"></Button>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>
                <!--Panel 3-->
                <Panel id="Panel3" width="60rem" class="sapUiResponsiveMargin" accessibleRole="Region" visible="false">
                    <headerToolbar>
                        <OverflowToolbar id="_IDGenOverflowToolbar1">
                            <Title id="_IDGenTitle1" text="Edit the book"/>
                        </OverflowToolbar>
                    </headerToolbar>   
                    <Breadcrumbs id="_IDGenBreadcrumbs2" currentLocationText="Add New Item">
                        <Link id="_IDGenLink1" text="Master"></Link>
                    </Breadcrumbs>

                    <HBox id="_IDGenHBox5" >
                        <VBox id="_IDGenVBox16" >
                            <Label id="_IDGenLabel12" text="Book ID"></Label>
                            <Input placeholder="Enter your title" id="itemCode" editable="false"></Input>
                        </VBox>
                        <VBox id="_IDGenVBox9" >
                            <Label id="_IDGenLabel6" text="Title"></Label>
                            <Input placeholder="Enter your title" id="title1"></Input>
                        </VBox>
                        <VBox id="_IDGenVBox10" >
                            <Label id="_IDGenLabel7" text="Author"></Label>
                            <Input placeholder="Enter the author name" id="author1"></Input>
                        </VBox>
                        <VBox id="_IDGenVBox11" >
                            <Label id="_IDGenLabel8" text="Price"></Label>
                            <Input placeholder="Enter the price" id="price1"></Input>
                        </VBox>
                    </HBox>

                    <HBox id="_IDGenHBox6" >
                        <VBox id="_IDGenVBox12" >
                            <Label id="_IDGenLabel9" text="Stock"></Label>
                            <Input placeholder="Enter the stock" id="stock1"></Input>
                        </VBox>
                        <VBox id="_IDGenVBox13" >
                            <Label id="_IDGenLabel10" text="Location"></Label>
                            <Input placeholder="Enter the location" id="location1"></Input>
                        </VBox>
                        <VBox id="_IDGenVBox14" >
                            <Label id="_IDGenLabel11" text="Genre"></Label>
                            <Input placeholder="Enter the genre" id="genre1"></Input>
                        </VBox>
                    </HBox>

                    <HBox id="_IDGenHBox7" >
                        <VBox id="_IDGenVBox15" >
                            <Button id="_IDGenButton1" press="updateItem" text="Update"></Button>
                        </VBox>
                    </HBox>
                </Panel>
                <!--Panel 4 - Place Order-->
                <Panel id="Panel4" width="60rem" class="sapUiResponsiveMargin" accessibleRole="Region" visible="false">
                    <headerToolbar>
                        <OverflowToolbar id="_IDGenOverflowToolbar2">
                            <Title id="_IDGenTitle2" text="Place an Order"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <HBox id="_IDGenHBoxOrder1">
                        <VBox id="_IDGenVBoxOrder1">
                            <Label id="_IDGenLabelBook" text="Book ID"></Label>
                            <Input placeholder="Enter Book ID" id="orderBookId"></Input>
                        </VBox>
                        <VBox id="_IDGenVBoxOrder2">
                            <Label id="_IDGenLabelQty" text="Quantity"></Label>
                            <Input placeholder="Enter quantity" id="orderQuantity" type="Number"></Input>
                        </VBox>
                    </HBox>
                    <HBox id="_IDGenHBoxOrder2">
                        <VBox id="_IDGenVBoxOrder3">
                            <Button id="_IDGenButtonOrder" press=".onSubmitOrder" text="Place Order"></Button>
                        </VBox>
                    </HBox>
                </Panel>

                <!--Panel 5 - View Orders-->
                <Panel id="Panel5" headerText="All Orders" visible="false" class="sapUiResponsiveMargin">
                    <Table id="ordersTable" items="{/Orders}">
                        <columns>
                            <Column id="_IDGenColumn8">
                                <Text id="_IDGenText13" text="Order ID"></Text>
                            </Column>
                            <Column id="_IDGenColumn9">
                                <Text id="_IDGenText14" text="Book ID"></Text>
                            </Column>
                            <Column id="_IDGenColumn10">
                                <Text id="_IDGenText15" text="Quantity"></Text>
                            </Column>
                            <Column id="_IDGenColumn11">
                                <Text id="_IDGenText16" text="Total Price"></Text>
                            </Column>
                            <Column id="_IDGenColumn12">
                                <Text id="_IDGenText17" text="Order Date"></Text>
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem id="_IDGenColumnListItem1">
                                <cells>
                                    <Text id="_IDGenText18" text="{ID}"></Text>
                                    <Text id="_IDGenText19" text="{book_ID}"></Text>
                                    <Text id="_IDGenText20" text="{quantity}"></Text>
                                    <Text id="_IDGenText21" text="{totalPrice}"></Text>
                                    <Text id="_IDGenText22" text="{orderDate}"></Text>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>
            </VBox>
        </HBox>
    </Page>
</mvc:View>