<mvc:View controllerName="thebookshop.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="homePage" showHeader="false">
        <content>
            <FlexBox
                class="bookshopLanding"
                justifyContent="Center"
                alignItems="Center"
                height="100%">
                <items>
                    <VBox
                        class="bookshopWelcomeCard"
                        alignItems="Center">
                        <Title
                            text="📚 The BookShop"
                            class="bookshopTitle"
                            textAlign="Center"/>
                        <Text
                            text="Your favourite place to discover and order books"
                            class="bookshopSubtitle"
                            textAlign="Center"/>
                        <HBox
                            justifyContent="Center"
                            class="sapUiMediumMarginTop"
                            renderType="Bare">
                            <Button
                                id="adminBtn"
                                text="Admin"
                                icon="sap-icon://manager"
                                press=".onAdminPressed"
                                type="Transparent"
                                class="bookshopAdminBtn sapUiMediumMarginEnd"/>
                            <Button
                                id="userBtn"
                                text="User"
                                icon="sap-icon://person-placeholder"
                                press=".onUserPressed"
                                type="Transparent"
                                class="bookshopUserBtn"/>
                        </HBox>
                    </VBox>
                </items>
            </FlexBox>
        </content>
    </Page>
</mvc:View>