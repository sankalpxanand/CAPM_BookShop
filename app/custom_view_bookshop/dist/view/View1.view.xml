<mvc:View controllerName="thebookshop.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout">
    <Page id="homePage" showHeader="false">
        <content>
            <VBox id="_IDGenVBox1"
                class="sapUiMediumMargin"
                justifyContent="Center"
                alignItems="Center"
                height="100%">

                <Title id="_IDGenTitle"
                    text="Welcome to The BookShop"
                    level="H1"
                    class="sapUiLargeMarginBottom"/>

                <Text id="_IDGenText"
                    text="Please select how you want to continue"
                    class="sapUiSmallMarginBottom"/>

                <HBox id="_IDGenHBox" justifyContent="Center" class="sapUiMediumMarginTop">
                    <Button
                        id="adminBtn"
                        text="Admin"
                        type="Emphasized"
                        icon="sap-icon://person-placeholder"
                        press=".onAdminPressed"
                        class="sapUiMediumMarginEnd"
                        width="10rem"/>
                    <Button
                        id="userBtn"
                        text="User"
                        type="Default"
                        icon="sap-icon://manager"
                        press=".onUserPressed"
                        width="10rem"/>
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>