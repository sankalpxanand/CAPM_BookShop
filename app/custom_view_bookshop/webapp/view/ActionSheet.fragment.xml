<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <ActionSheet id="actionsheet" title="Actions">
        <buttons>
            <Button
                id="_IDGenButton4"
                icon="sap-icon://cart"
                text="Order"
                press="onOrderPress"
                visible="{= ${appState>/role} === 'user'}"/>
            <Button
                id="_IDGenButton5"
                icon="sap-icon://delete"
                text="Delete"
                press="onDeletePress"
                visible="{= ${appState>/role} === 'admin'}"/>
            <Button
                id="_IDGenButton6"
                icon="sap-icon://edit"
                text="Edit"
                press="onEditPress"
                visible="{= ${appState>/role} === 'admin'}"/>
        </buttons>
    </ActionSheet>
</core:FragmentDefinition>