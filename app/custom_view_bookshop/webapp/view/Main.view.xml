<mvc:View controllerName="thebookshop.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt">
    <Page id="mainPage" showHeader="false">
        <content>
            <HBox id="mainHBox" height="100%">
                <!-- Side Navigation -->
                <VBox id="sideNavVBox" class="bookshopSideNav" height="100vh">
                    <tnt:ToolHeader id="toolHeader" class="bookshopToolHeader">
                        <Button
                            id="menuBtn"
                            icon="sap-icon://menu2"
                            type="Transparent"
                            tooltip="Menu"
                            press=".onCollapseExpandPress">
                            <layoutData>
                                <OverflowToolbarLayoutData priority="NeverOverflow"/>
                            </layoutData>
                        </Button>
                        <Title text="The BookShop" wrapping="false" id="shopTitle">
                            <layoutData>
                                <OverflowToolbarLayoutData priority="Disappear"/>
                            </layoutData>
                        </Title>
                    </tnt:ToolHeader>
                    <tnt:SideNavigation id="sideNavigation" expanded="true" class="bookshopToolBody">
                        <tnt:NavigationList id="mainNavList">
                            <tnt:NavigationListItem
                                id="addBookNav"
                                text="Add Book"
                                icon="sap-icon://add"
                                press=".onAddBookPressed"/>
                            <tnt:NavigationListItem
                                id="viewBooksNav"
                                text="View Books"
                                icon="sap-icon://kpi-managing-my-area"
                                press=".onViewBooksPressed"/>
                            <tnt:NavigationListItem
                                id="placeOrderNav"
                                text="Place Order"
                                icon="sap-icon://cart"
                                press=".onPlaceOrderPressed"/>
                            <tnt:NavigationListItem
                                id="viewOrdersNav"
                                text="View Orders"
                                icon="sap-icon://sales-order"
                                press=".onViewOrdersPressed"/>
                        </tnt:NavigationList>
                        <tnt:fixedItem>
                            <tnt:NavigationList id="fixedNavList">
                                <tnt:NavigationListItem
                                    id="logoutNav"
                                    text="Logout"
                                    icon="sap-icon://log"
                                    press=".onLogoutPressed"/>
                            </tnt:NavigationList>
                        </tnt:fixedItem>
                    </tnt:SideNavigation>
                </VBox>

                <!-- Profile Card -->
                <VBox class="bookshopProfile">
                    <Panel class="bookshopProfileCard">
                        <VBox class="bookshopProfileHeader" alignItems="Center">
                            <Avatar
                                displaySize="L"
                                class="bookshopAvatar"
                                initials="{= ${appState>/name} ? ${appState>/name}.charAt(0).toUpperCase() : '?'}"/>
                            <Title
                                text="{appState>/name}"
                                class="bookshopProfileName sapUiSmallMarginTop"
                                textAlign="Center"/>
                            <Text
                                text="{= ${appState>/role} === 'admin' ? 'Administrator' : 'User'}"
                                class="bookshopProfileRole"/>
                        </VBox>
                        <VBox class="bookshopProfileDetails">
                            <Label text="EMAIL" class="bookshopProfileLabel"/>
                            <Text text="{appState>/email}" class="bookshopProfileValue"/>
                            <Label text="PHONE" class="bookshopProfileLabel"/>
                            <Text text="{appState>/phone}" class="bookshopProfileValue"/>
                        </VBox>
                    </Panel>
                </VBox>
            </HBox>
        </content>
    </Page>
</mvc:View>