{
  "_version": "1.83.0",
  "sap.app": {
    "id": "thebookshop",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.22.0",
      "toolsId": "a65a6880-6ea1-440e-89f6-236515d7ebdf"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/catalog/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "thebookshop-display": {
          "semanticObject": "thebookshop",
          "action": "display",
          "title": "Custom View Bookshop",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "thebookshop.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "thebookshop.view",
        "async": true,
        "viewPath": "thebookshop.view"
      },
      "routes": [
        {
          "name": "RouteView1",
          "pattern": ":?query:",
          "target": ["TargetView1"]
        },
        {
          "name": "RouteMain",
          "pattern": "main",
          "target": ["TargetMain"]
        },
        {
          "name": "RouteAddBook",
          "pattern": "addbook",
          "target": ["TargetAddBook"]
        },
        {
          "name": "RouteViewBooks",
          "pattern": "viewbooks",
          "target": ["TargetViewBooks"]
        },
        {
          "name": "RouteEditBook",
          "pattern": "editbook/:bookId:",
          "target": ["TargetEditBook"]
        },
        {
          "name": "RouteViewOrders",
          "pattern": "vieworders",
          "target": ["TargetViewOrders"]
        },
        {
          "name": "RoutePlaceOrder",
          "pattern": "placeorder/:bookId:",
          "target": ["TargetPlaceOrder"]
        }
      ],
      "targets": {
        "TargetView1": {
          "id": "View1",
          "name": "View1"
        },
        "TargetMain": {
          "id": "Main",
          "name": "Main",
          "controlId": "app",
          "controlAggregation": "pages"
        },
        "TargetAddBook": {
          "id": "AddBook",
          "name": "AddBook",
          "controlId": "app",
          "controlAggregation": "pages"
        },
        "TargetViewBooks": {
          "id": "ViewBooks",
          "name": "ViewBooks",
          "controlId": "app",
          "controlAggregation": "pages"
        },
        "TargetEditBook": {
          "id": "EditBook",
          "name": "EditBook",
          "controlId": "app",
          "controlAggregation": "pages"
        },
        "TargetPlaceOrder": {
          "id": "PlaceOrder",
          "name": "PlaceOrder",
          "controlId": "app",
          "controlAggregation": "pages"
        },
        "TargetViewOrders": {
          "id": "ViewOrders",
          "name": "ViewOrders",
          "controlId": "app",
          "controlAggregation": "pages"
        }
      }
    },
    "rootView": {
      "viewName": "thebookshop.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "capm.books"
  }
}
